# Shared
MODULE_VERSION=0.1.3
MAIN_BASE_URL=http://main-system:3000

# Paths
WEB_BASE_PATH=/customer-profiling
API_BASE_PATH=/api/customer-profiling

# API
API_PORT=3000
DATABASE_URL=postgresql://customer_profiling:customer_profiling@postgres:5432/customer_profiling?schema=public
MODULE_REGISTRY_CACHE_TTL_MS=60000

# Web build/runtime
WEB_PORT=80
VITE_WEB_BASE_PATH=/customer-profiling
VITE_API_BASE_PATH=/api/customer-profiling
VITE_APP_VERSION=0.1.3

# Postgres
POSTGRES_DB=customer_profiling
POSTGRES_USER=customer_profiling
POSTGRES_PASSWORD=customer_profiling
POSTGRES_PORT=5432
